s = input()
s = int(s.replace("s", ""))
H = int(s/3600)
M = int((s - 3600 * H) / 60)
S = int(s - 3600 * H - 60 * M)
if H < 10:
    H = "0" + str(H)
if S < 10:
    S = "0" + str(S)
if M < 10:
    M = "0" + str(M)
print(f"{H}:{M}:{S}")
# simple, but need to think twice.
# be careful with the "int" and " float"! that's a really important issue in Python.
